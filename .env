# ══════════════════════════════════════════════════════════════
# VoiceAI Backend — Environment Variables
# Copy this file to .env and fill in all values before running.
# NEVER commit the filled-in .env to version control.
# ══════════════════════════════════════════════════════════════

# ── CORE AI SERVICES (required) ───────────────────────────────

# Deepgram — Speech-to-Text
# Get your key at: https://console.deepgram.com
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# Groq — LLM (Llama 3.1)
# Get your key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# ElevenLabs — Text-to-Speech
# Get your key at: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# ElevenLabs Voice IDs
# Default: Rachel (English) and Adam (Hindi fallback)
# Browse voices at: https://elevenlabs.io/voice-library
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_HINDI_VOICE_ID=pNInz6obpgDQGcFmaJgB

# ── TWILIO (required for phone calls + SMS + Polly fallback) ──

# Twilio Account SID and Auth Token
# Found at: https://console.twilio.com → Account Info
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here

# Your Twilio phone number (E.164 format)
# e.g. +12025551234 or +919876543210
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# ── UPGRADE 2: OpenWeatherMap ─────────────────────────────────

# OpenWeatherMap API key — free tier is sufficient
# Sign up at: https://openweathermap.org/api
OPENWEATHERMAP_API_KEY=your_openweathermap_api_key_here

# ── UPGRADE 3: NewsAPI ────────────────────────────────────────

# NewsAPI key — free tier gives 100 requests/day
# Sign up at: https://newsapi.org/register
NEWS_API_KEY=your_newsapi_key_here

# ── UPGRADE 4: Google Calendar ────────────────────────────────

# Path to your Google service account JSON credentials file
# Create at: https://console.cloud.google.com → IAM → Service Accounts
# Download the JSON key and store it securely (do NOT commit it)
GOOGLE_SERVICE_ACCOUNT_JSON=/path/to/your/service-account.json

# Google Calendar ID to book events into
# Use "primary" for the service account's default calendar,
# or share a specific calendar with the service account email and paste its ID here
GOOGLE_CALENDAR_ID=primary

# Timezone for calendar event creation (IANA tz name)
# Full list: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TIMEZONE=Asia/Kolkata

# ── UPGRADE 6: Postgres / Supabase ────────────────────────────

# Async Postgres connection string (asyncpg format)
# Supabase:  postgresql://postgres:<password>@db.<project>.supabase.co:5432/postgres
# Local:     postgresql://user:password@localhost:5432/voiceai
# Render:    Copy from your Render Postgres dashboard → Connection String (External)
DATABASE_URL=postgresql://user:password@localhost:5432/voiceai

# ── UPGRADE 9: Rate limiting ──────────────────────────────────

# Maximum number of calls allowed per phone number within the window
RATE_LIMIT_MAX_CALLS=5

# Rolling window for rate limiting, in seconds (default: 3600 = 1 hour)
RATE_LIMIT_WINDOW_SECS=3600

# ── OPTIONAL: Redis (production rate limiting) ────────────────
# Uncomment and set if you swap the in-memory rate limiter for Redis
# pip install redis[asyncio]
# REDIS_URL=redis://localhost:6379/0
